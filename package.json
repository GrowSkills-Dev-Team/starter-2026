{
  "name": "starter-2026",
  "version": "1.0.0",
  "description": "A custom WordPress theme built with ACF (Advanced Custom Fields) blocks.",
  "main": "index.js",
  "scripts": {
    "build:css": "npx postcss css/frontend.css -o assets/build/front-end.css && npx postcss css/editor.css -o assets/build/editor-gs.css",
    "watch:frontend": "npx postcss css/frontend.css -o assets/build/front-end.css --watch",
    "watch:editor": "npx postcss css/editor.css -o assets/build/editor-gs.css --watch",
    "watch:css": "npm-run-all --parallel watch:frontend watch:editor",
    "new:block": "node new-block.js",
    "zip": "node zip-theme.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.23",
    "cssnano": "^7.1.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
